<launch>
    <!-- ASR 节点：语音识别 -->
    <node pkg="asr_tts" type="asr_node.py" name="asr_node" output="screen" />

    <!-- TTS 节点：语音合成 -->
    <node pkg="asr_tts" type="tts_node.py" name="tts_node" output="screen" />

    <!-- CADE 控制器：LLM 决策 -->
    <!-- 注意：需要在 CADE 项目根目录运行 -->
    <!-- <node pkg="asr_tts" type="cade_bridge.py" name="cade_bridge" output="screen" /> -->
</launch>
