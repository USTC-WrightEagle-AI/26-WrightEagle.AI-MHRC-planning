<launch>
    <!-- ===== 音频设备参数 ===== -->
    <arg name="mic_id" default="MEETEASY" />
    <arg name="speaker_id" default="USB2.0 Device" />

    <!-- ===== 功能开关 ===== -->
    <arg name="enable_speaker_doa" default="true" />
    <arg name="enable_doorbell" default="true" />

    <!-- ===== 音频采集节点 (唯一打开麦克风的节点) ===== -->
    <!-- 发布 /audio/raw (Float32MultiArray), 供 ASR / Doorbell 订阅 -->
    <node pkg="asr_tts" type="audio_capture_node.py" name="audio_capture_node" output="screen">
        <param name="device_name" value="$(arg mic_id)" />
        <param name="sample_rate" value="16000" />
        <param name="chunk_duration" value="0.2" />
    </node>

    <!-- ===== TTS 节点 (必须) ===== -->
    <node pkg="asr_tts" type="tts_node.py" name="tts_node" output="screen">
        <param name="device_name" value="$(arg speaker_id)" />
        <param name="play" value="true" />
    </node>

    <!-- ===== ASR 节点 (必须, 订阅 /audio/raw) ===== -->
    <node pkg="asr_tts" type="asr_node.py" name="asr_node" output="screen" />

    <!-- ===== Speaker DOA 节点 (说话人识别 + 声源定位) ===== -->
    <node pkg="asr_tts" type="speaker_doa_node.py" name="speaker_doa_node" output="screen"
          if="$(arg enable_speaker_doa)">
        <param name="serial_device" value="auto" />
        <param name="baud" value="115200" />
        <param name="threshold" value="0.3" />
        <param name="detect_seconds" value="0.5" />
        <param name="enroll_seconds" value="5.0" />
        <param name="active_channels" value="0,1,2,3,4,5" />
        <param name="geometry" value="circle6" />
        <param name="num_mics" value="6" />
        <param name="radius_m" value="0.035" />
        <param name="score_threshold" value="0.0" />
    </node>

    <!-- ===== Doorbell 节点 (订阅 /audio/raw) ===== -->
    <node pkg="asr_tts" type="doorbell_node.py" name="doorbell_node" output="screen"
          if="$(arg enable_doorbell)">
        <param name="threshold" value="0.5" />
        <param name="buffer_duration" value="2.0" />
        <param name="overlap_duration" value="1.0" />
        <param name="cooldown_sec" value="3.0" />
    </node>
</launch>
