# =================================================================
# CADE 机器人配置文件模板 (Refactored Architecture)
# 使用方法: cp .env.example .env 然后修改以下变量
# =================================================================

# 运行模式: CLOUD (开发/云端) 或 LOCAL (Orin/本地)
CADE_MODE=CLOUD

# 机器人名称
CADE_ROBOT_NAME=LARA

# -------------------- 云端配置 --------------------
CADE_CLOUD_BASE_URL=https://api.deepseek.com
CADE_CLOUD_API_KEY=sk-你的真实API密钥
CADE_CLOUD_MODEL=deepseek-chat

# -------------------- 本地配置 (Ollama) --------------------
CADE_LOCAL_BASE_URL=http://localhost:11434/v1
CADE_LOCAL_API_KEY=ollama
CADE_LOCAL_MODEL=qwen3:8b

# -------------------- LLM 参数 --------------------
CADE_TEMPERATURE=0.7
CADE_MAX_TOKENS=512
CADE_TIMEOUT=30

# -------------------- 视觉配置 --------------------
# YOLO 模型路径
CADE_YOLO_MODEL=yolo11x-seg.pt
# RealSense 序列号
CADE_REALSENSE_SERIAL=333422301212
# 检测置信度阈值
CADE_YOLO_CONF=0.25
# 检测设备 (cuda / cpu)
CADE_YOLO_DEVICE=cuda
